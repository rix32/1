-- Helpers
local function backupAnimations(char)
    pcall(function()
        if char and char:FindFirstChild("Animate") then
            for _, val in ipairs(char.Animate:GetChildren()) do
                if val:IsA("StringValue") then
                    local anim = val:FindFirstChildOfClass("Animation")
                    if anim then
                        originalAnims[val.Name] = anim.AnimationId
                    end
                end
            end
        end
    end)
end

local function tTween(obj, info, property)
    if not effectsEnabled then
        for k, v in pairs(property) do
            obj[k] = v
        end
        return nil
    end
    local tween = TweenService:Create(obj, info, property)
    tween:Play()
    return tween
end

local function bindScrollCanvas(scrollFrame, layout)
    local function updateCanvas()
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
    task.defer(updateCanvas)
end

