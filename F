local function applyWalkAnimation(animId)
    task.spawn(function()
        pcall(function()
            local animate = Character and Character:FindFirstChild("Animate")
            if not animate then return end

            local walk = animate:FindFirstChild("walk")
            local run = animate:FindFirstChild("run")
            if walk and walk:FindFirstChildOfClass("Animation") then
                walk:FindFirstChildOfClass("Animation").AnimationId = animId
            end
            if run and run:FindFirstChildOfClass("Animation") then
                run:FindFirstChildOfClass("Animation").AnimationId = animId
            end
            if Humanoid then
                Humanoid.WalkSpeed = Humanoid.WalkSpeed + 0.1
                task.wait(0.1)
                Humanoid.WalkSpeed = walkSpeedValue
            end
        end)
    end)
end

