-- ─── Connection Registry | سجل الاتصالات للتنظيف الآمن ─────────
local Connections = {}

local function track(conn)
    table.insert(Connections, conn)
    return conn
end

local function disconnectAll()
    for _, c in ipairs(Connections) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(Connections)
end

-- ─── Helpers | دوال مساعدة ──────────────────────────────────────
local function getRoot()
    return Character and Character:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    return Character and Character:FindFirstChildOfClass("Humanoid")
end

local function tween(obj, props, t, style, dir)
    if not State.effectsOn then
        for k, v in pairs(props) do obj[k] = v end
        return
    end
    TweenService:Create(obj, TweenInfo.new(t or 0.25, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props):Play()
end

local function applyGradient(parent, c0, c1, rot)
    local g = parent:FindFirstChildOfClass("UIGradient") or Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c0),
        ColorSequenceKeypoint.new(1, c1),
    })
    g.Rotation = rot or 45
    g.Parent = parent
    return g
end

local function makeCorner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function makeStroke(parent, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or THEME.Stroke
    s.Thickness = thick or 1.2
    s.Transparency = trans or 0.3
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function bindScroll(scroll, layout)
    local function upd()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(upd)
    task.defer(upd)
end

-- ─── Animation Backup | نسخ احتياطي للحركات ───────────────────
local function backupAnims(char)
    pcall(function()
        local anim = char and char:FindFirstChild("Animate")
        if not anim then return end
        for _, v in ipairs(anim:GetChildren()) do
            if v:IsA("StringValue") then
                local a = v:FindFirstChildOfClass("Animation")
                if a then State.originalAnims[v.Name] = a.AnimationId end
            end
        end
    end)
end

task.spawn(function()
    if not Character then Character = LocalPlayer.CharacterAdded:Wait() end
    Humanoid = Character:WaitForChild("Humanoid")
    State.defaultWalk = Humanoid.WalkSpeed
    backupAnims(Character)
end)

