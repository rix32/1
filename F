local function addNav(id, emoji, en, ar)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 148, 0, 46)
    b.BackgroundColor3 = THEME.BgCard
    b.Font = Enum.Font.GothamSemibold
    b.Text = emoji .. "\n" .. en
    b.TextColor3 = THEME.TextMuted
    b.TextSize = 10
    b.Parent = Sidebar
    makeCorner(b, 9)
    makeStroke(b, THEME.Purple, 0.8, 0.65)

    NavBtns[id] = b
    b.MouseEnter:Connect(function()
        if State.activePage ~= id then tween(b, {BackgroundColor3 = THEME.Hover}, 0.15) end
    end)
    b.MouseLeave:Connect(function()
        if State.activePage ~= id then tween(b, {BackgroundColor3 = THEME.BgCard}, 0.15) end
    end)
    b.MouseButton1Click:Connect(function()
        for _, pg in pairs(Pages) do pg.Visible = false end
        Pages[id].Visible = true
        State.activePage = id
        for nid, nb in pairs(NavBtns) do
            local g = nb:FindFirstChildOfClass("UIGradient")
            if g then g:Destroy() end
            nb.BackgroundColor3 = THEME.BgCard
            nb.TextColor3 = THEME.TextMuted
        end
        applyGradient(b, THEME.Purple, THEME.Cyan, 60)
        b.TextColor3 = THEME.TextGlow
    end)
end

