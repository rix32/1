    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Font = Enum.Font.GothamSemibold
    text.Text = labelEn .. "\n" .. labelAr
    text.TextColor3 = THEME.TextMuted
    text.TextSize = 10
    text.Parent = btn
    
    btn.MouseEnter:Connect(function()
        tTween(btn, TweenInfo.new(0.2), {BackgroundColor3 = THEME.ButtonHover})
        tTween(text, TweenInfo.new(0.2), {TextColor3 = THEME.TextWhite})
    end)
    btn.MouseLeave:Connect(function()
        if activePage ~= name then
            tTween(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 20, 30)})
            tTween(text, TweenInfo.new(0.2), {TextColor3 = THEME.TextMuted})
        end
    end)
    
    btn.MouseButton1Click:Connect(function()
        for pageName, pFrame in pairs(pages) do
            pFrame.Visible = false
        end
        pages[name].Visible = true
        activePage = name
        
        -- Reset other nav buttons
        for _, otherBtn in ipairs(Sidebar:GetChildren()) do
            if otherBtn:IsA("TextButton") then
                otherBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
                otherBtn.TextLabel.TextColor3 = THEME.TextMuted
            end
        end
        btn.BackgroundColor3 = Color3.fromRGB(0, 40, 80)
        text.TextColor3 = THEME.AccentGlow
    end)
end

