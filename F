local function cleanupFlightInstances()
    local root = getRoot()
    if not root then return end

    for _, name in ipairs({
        "F16_Attachment",
        "F16_AlignOrientation",
        "F16_LinearVelocity",
        "F16_BodyGyro",
        "F16_BodyVelocity",
    }) do
        local inst = root:FindFirstChild(name)
        if inst then
            inst:Destroy()
        end
    end
end

