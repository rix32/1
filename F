local function applyWalk(id_a)
    task.spawn(function()
        pcall(function()
            local a = Character and Character:FindFirstChild("Animate")
            if not a then return end
            for _, n in ipairs({"walk", "run"}) do
                local v = a:FindFirstChild(n)
                if v and v:FindFirstChildOfClass("Animation") then
                    v:FindFirstChildOfClass("Animation").AnimationId = id_a
                end
            end
            local h = getHum()
            if h then h.WalkSpeed += 0.1; task.wait(0.08); h.WalkSpeed = State.walkSpeed end
        end)
    end)
end

