local function startFlight()
    local root = getRoot()
    local hum = getHum()
    if not root or not hum then return end

    stopFlight()
    State.flightOn = true
    hum.PlatformStand = true
    cleanupFlightPhysics()

    local align, mover
    local modern = pcall(function()
        local att = Instance.new("Attachment")
        att.Name = "F16_Att"
        att.Parent = root

        align = Instance.new("AlignOrientation")
        align.Name = "F16_Align"
        align.Mode = Enum.OrientationAlignmentMode.OneAttachment
        align.Attachment0 = att
        align.RigidityEnabled = true
        align.MaxTorque = math.huge
        align.Responsiveness = 200
        align.Parent = root

        mover = Instance.new("LinearVelocity")
        mover.Name = "F16_LinVel"
        mover.Attachment0 = att
        mover.MaxForce = math.huge
        mover.VectorVelocity = Vector3.zero
        mover.RelativeTo = Enum.ActuatorRelativeTo.World
        mover.Parent = root
    end)

    if not modern then
        cleanupFlightPhysics()
        local bg = Instance.new("BodyGyro")
        bg.Name = "F16_BodyGyro"
        bg.P = 9e4
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.CFrame = root.CFrame
        bg.Parent = root
        local bv = Instance.new("BodyVelocity")
        bv.Name = "F16_BodyVel"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Velocity = Vector3.zero
        bv.Parent = root
        align, mover = bg, bv
    end

    syncFlightBtn()

    State.flightConn = track(RunService.RenderStepped:Connect(function()
        if not State.flightOn or not root.Parent then
            stopFlight()
            return
        end
        local cam = Camera
        if not cam then return end

        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.yAxis end

        if align:IsA("AlignOrientation") then
            align.CFrame = cam.CFrame
        else
            align.CFrame = cam.CFrame
        end

        -- Auto-stabilizer | مثبت تلقائي — لا يهوي عند ترك الأزرار
        if dir.Magnitude > 0 then
            local vel = dir.Unit * State.flightSpeed
            if mover:IsA("LinearVelocity") then
                mover.VectorVelocity = vel
            else
                mover.Velocity = vel
            end
        else
            if mover:IsA("LinearVelocity") then
                mover.VectorVelocity = Vector3.zero
            else
                mover.Velocity = Vector3.zero
            end
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
    end))
end

local function startWalkBoost()
    stopWalkBoost()
    State.walkBoostOn = true
    syncWalkBtn()
    pcall(function()
        local hum = getHum()
        if hum then hum.WalkSpeed = State.walkSpeed end
    end)
    -- Anti-reset loop | حلقة منع إعادة الضبط من سكربتات اللعبة
    State.walkConn = track(RunService.Heartbeat:Connect(function()
        if not State.walkBoostOn then return end
        pcall(function()
            local hum = getHum()
            if hum and hum.WalkSpeed ~= State.walkSpeed then
                hum.WalkSpeed = State.walkSpeed
            end
        end)
    end))
end

local function startInfJump()
    stopInfJump()
    State.infJumpOn = true
    State.infJumpConn = track(UserInputService.JumpRequest:Connect(function()
        if not State.infJumpOn then return end
        pcall(function()
            local hum = getHum()
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    end))
end

local function startNoclip()
    stopNoclip()
    State.noclipOn = true
    table.clear(State.noclipSaved)
    State.noclipConn = track(RunService.Stepped:Connect(function()
        if not State.noclipOn or not Character then return end
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                if State.noclipSaved[part] == nil then
                    State.noclipSaved[part] = part.CanCollide
                end
                part.CanCollide = false
            end
        end
    end))
end

-- ESP via Drawing API (executor) + Highlight fallback
local DrawingLib = Drawing or (getgenv and getgenv().Drawing) or nil

local function createESPDrawing(player)
    if player == LocalPlayer then return end
    local pack = {}

    if DrawingLib then
        pack.box = DrawingLib.new("Square")
        pack.box.Thickness = 1.5
        pack.box.Filled = false
        pack.box.Color = THEME.Cyan
        pack.box.Visible = false

        pack.name = DrawingLib.new("Text")
        pack.name.Size = 14
        pack.name.Center = true
        pack.name.Outline = true
        pack.name.Color = THEME.TextWhite
        pack.name.Visible = false

        pack.dist = DrawingLib.new("Text")
        pack.dist.Size = 12
        pack.dist.Center = true
        pack.dist.Outline = true
        pack.dist.Color = THEME.Purple
        pack.dist.Visible = false
    else
        -- Fallback Highlight | بديل للرؤية
        pcall(function()
            if player.Character then
                pack.highlight = Instance.new("Highlight")
                pack.highlight.Name = "F16_ESP"
                pack.highlight.FillColor = THEME.Purple
                pack.highlight.OutlineColor = THEME.Cyan
                pack.highlight.FillTransparency = 0.7
                pack.highlight.Parent = player.Character
            end
        end)
    end

    State.espDrawings[player] = pack
end

local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(sp.X, sp.Y), onScreen, sp.Z
end

local function startESP()
    stopESP()
    State.espOn = true

    for _, plr in ipairs(Players:GetPlayers()) do
        createESPDrawing(plr)
    end

    track(Players.PlayerAdded:Connect(function(plr)
        if State.espOn then createESPDrawing(plr) end
    end))

    track(Players.PlayerRemoving:Connect(function(plr)
        local pack = State.espDrawings[plr]
        if pack then
            pcall(function()
                if pack.box then pack.box:Remove() end
                if pack.name then pack.name:Remove() end
                if pack.dist then pack.dist:Remove() end
                if pack.highlight then pack.highlight:Destroy() end
            end)
            State.espDrawings[plr] = nil
        end
    end))

    State.espConn = track(RunService.RenderStepped:Connect(function()
        if not State.espOn then return end

        for plr, pack in pairs(State.espDrawings) do
            local char = plr.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")

            if not root or not hum or hum.Health <= 0 then
                if pack.box then pack.box.Visible = false end
                if pack.name then pack.name.Visible = false end
                if pack.dist then pack.dist.Visible = false end
                if pack.highlight then pack.highlight.Parent = nil end
                continue
            end

            if not DrawingLib then
                if pack.highlight then
                    local show = State.espOn and (State.espBoxOn or State.espNameOn or State.espDistOn)
                    pack.highlight.Enabled = show
                    if show and pack.highlight.Parent ~= char then
                        pack.highlight.Parent = char
                    elseif not show then
                        pack.highlight.Parent = nil
                    end
                end
                continue
            end

            local cf, hrpSize = root.CFrame, Vector3.new(2, 3, 1)
            local corners = {
                cf * Vector3.new(-hrpSize.X, hrpSize.Y, -hrpSize.Z),
                cf * Vector3.new( hrpSize.X, hrpSize.Y, -hrpSize.Z),
                cf * Vector3.new(-hrpSize.X,-hrpSize.Y, -hrpSize.Z),
                cf * Vector3.new( hrpSize.X,-hrpSize.Y, -hrpSize.Z),
                cf * Vector3.new(-hrpSize.X, hrpSize.Y,  hrpSize.Z),
                cf * Vector3.new( hrpSize.X, hrpSize.Y,  hrpSize.Z),
                cf * Vector3.new(-hrpSize.X,-hrpSize.Y,  hrpSize.Z),
                cf * Vector3.new( hrpSize.X,-hrpSize.Y,  hrpSize.Z),
            }

            local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
            local anyOn = false
            for _, wp in ipairs(corners) do
                local sc, vis = worldToScreen(wp)
                if vis then
                    anyOn = true
                    minX, minY = math.min(minX, sc.X), math.min(minY, sc.Y)
                    maxX, maxY = math.max(maxX, sc.X), math.max(maxY, sc.Y)
                end
            end

            local dist = (root.Position - (getRoot() and getRoot().Position or root.Position)).Magnitude

            if pack.box then
                pack.box.Visible = State.espBoxOn and anyOn
                if anyOn and State.espBoxOn then
                    pack.box.Position = Vector2.new(minX, minY)
                    pack.box.Size = Vector2.new(maxX - minX, maxY - minY)
                end
            end
            if pack.name then
                pack.name.Visible = State.espNameOn and anyOn
                if anyOn and State.espNameOn then
                    pack.name.Text = "👤 " .. plr.DisplayName
                    pack.name.Position = Vector2.new((minX + maxX) / 2, minY - 18)
                end
            end
            if pack.dist then
                pack.dist.Visible = State.espDistOn and anyOn
                if anyOn and State.espDistOn then
                    pack.dist.Text = string.format("📏 %.0fm", dist)
                    pack.dist.Position = Vector2.new((minX + maxX) / 2, maxY + 4)
                end
            end
        end
    end))
end

