local function applyWalkAnimation(animId)
    pcall(function()
        local animate = Character:FindFirstChild("Animate")
        if animate then
            local walk = animate:FindFirstChild("walk")
            local run = animate:FindFirstChild("run")
            if walk and walk:FindFirstChildOfClass("Animation") then
                walk:FindFirstChildOfClass("Animation").AnimationId = animId
            end
            if run and run:FindFirstChildOfClass("Animation") then
