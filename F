-- نظام فلترة وتطهير المنصات المقفلة | Smart Verification Engine
local function executeSafeTeleport(targetPart)
    local activePlayer = PlayersService.LocalPlayer
    local myCharacter = activePlayer.Character
    if myCharacter and myCharacter:FindFirstChild("HumanoidRootPart") then
        local targetCFrame = targetPart.CFrame
        
        -- مراقبة عداد الفوز لمنع التعليق | Leaderstats Validation Check
        local statsFolder = activePlayer:FindFirstChild("leaderstats")
        local winCounter = statsFolder and (statsFolder:FindFirstChild("Wins") or statsFolder:FindFirstChild("الانتصارات"))
        local startValue = winCounter and winCounter.Value or 0
        
        -- تنفيذ قفزة الإحداثيات | Execute Coordinates Shift
        myCharacter.HumanoidRootPart.CFrame = targetCFrame + Vector3.new(0, 2.5, 0)
        
        -- مؤقت ذكي لتجنب البوابات المغلقة | Auto-Skip Failure Validation
        local iterations = 0
        while getgenv().ExecutionState and iterations < 12 do
            task.wait(0.01)
            iterations = iterations + 1
            local currentValue = winCounter and winCounter.Value or 0
            if currentValue > startValue then
                break -- تمت العملية بنجاح | Success Detected
            end
        end
    end
end

-- محرك التجميع والمسح الشامل | Core Mapping & Scanning Engine
task.spawn(function()
    while true do
        task.wait(0.25)
        if getgenv().ExecutionState then
            pcall(function()
                local winZone = WorkspaceService:FindFirstChild("Map") and WorkspaceService.Map:FindFirstChild("Win")
                if winZone then
                    local zonesList = winZone:GetChildren()
                    
                    -- الفرز التصاعدي للمسار | Sorted Progression Mapping
                    table.sort(zonesList, function(first, second)
                        local idFirst = tonumber(first.Name:match("%d+")) or 0
                        local idSecond = tonumber(second.Name:match("%d+")) or 0
                        return idFirst < idSecond
                    end)
                    
                    for _, zoneItem in ipairs(zonesList) do
                        if not getgenv().ExecutionState then break end
                        
                        -- نظام الحظر الذكي لـ الكلمات المدفوعة | Anti-Premium Gate Exclusion
                        local label = zoneItem.Name:lower()
                        if not label:match("vip") and not label:match("pass") and not label:match("double") and not label:match("aura") then
                            local dynamicPart = zoneItem:FindFirstChild("WinPart")
                            if dynamicPart and dynamicPart:IsA("BasePart") then
                                executeSafeTeleport(dynamicPart)
                                task.wait(0.15)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- رادار التطهير التلقائي لواجهات المتجر المنبثقة | Anti-Purchase Popups Purge
