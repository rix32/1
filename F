-- Clean flight physics | تنظيف فيزياء الطيران
local function cleanupFlightPhysics()
    local root = getRoot()
    if not root then return end
    for _, n in ipairs({"F16_Att", "F16_Align", "F16_LinVel", "F16_BodyGyro", "F16_BodyVel"}) do
        local i = root:FindFirstChild(n)
        if i then i:Destroy() end
    end
end

local FlightToggleBtn

local function syncFlightBtn()
    if not FlightToggleBtn then return end
    if State.flightOn then
        FlightToggleBtn.Text = "✅ ON | تشغيل الطيران"
        FlightToggleBtn.TextColor3 = THEME.TextGlow
        FlightToggleBtn.BackgroundColor3 = THEME.OnGreenBg
        applyGradient(FlightToggleBtn, THEME.OnGreen, THEME.CyanDim, 90)
    else
        FlightToggleBtn.Text = "❌ OFF | إيقاف الطيران"
        FlightToggleBtn.TextColor3 = THEME.OffRed
        FlightToggleBtn.BackgroundColor3 = THEME.OffRedBg
        applyGradient(FlightToggleBtn, THEME.OffRedBg, THEME.PurpleDeep, 90)
    end
end

-- Stop Flight safely | إيقاف الطيران بأمان
local function stopFlight()
    State.flightOn = false
    if State.flightConn then
        pcall(function() State.flightConn:Disconnect() end)
        State.flightConn = nil
    end
    cleanupFlightPhysics()
    local hum = getHum()
    if hum then hum.PlatformStand = false end
    syncFlightBtn()
end

-- Stop Walk Boost | إيقاف تعزيز السرعة
local WalkToggleBtn

local function syncWalkBtn()
    if not WalkToggleBtn then return end
    if State.walkBoostOn then
        WalkToggleBtn.Text = "✅ BOOST ON | التعزيز مفعّل"
        WalkToggleBtn.TextColor3 = THEME.TextGlow
        WalkToggleBtn.BackgroundColor3 = THEME.OnGreenBg
    else
        WalkToggleBtn.Text = "❌ BOOST OFF | التعزيز متوقف"
        WalkToggleBtn.TextColor3 = THEME.OffRed
        WalkToggleBtn.BackgroundColor3 = THEME.OffRedBg
    end
end

local function stopWalkBoost()
    State.walkBoostOn = false
    if State.walkConn then
        pcall(function() State.walkConn:Disconnect() end)
        State.walkConn = nil
    end
    pcall(function()
        local hum = getHum()
        if hum then hum.WalkSpeed = State.defaultWalk end
    end)
    State.walkSpeed = State.defaultWalk
    syncWalkBtn()
end

-- Stop Emote | إيقاف الرقصة فوراً
local function stopEmote()
    if State.activeTrack then
        pcall(function()
            State.activeTrack:Stop(0)
            State.activeTrack:Destroy()
        end)
        State.activeTrack = nil
    end
end

-- Stop Infinite Jump | إيقاف القفز اللانهائي
local function stopInfJump()
    State.infJumpOn = false
    if State.infJumpConn then
        pcall(function() State.infJumpConn:Disconnect() end)
        State.infJumpConn = nil
    end
end

-- Stop Noclip | إيقاف النوكليب واستعادة التصادم
local function stopNoclip()
    State.noclipOn = false
    if State.noclipConn then
        pcall(function() State.noclipConn:Disconnect() end)
        State.noclipConn = nil
    end
    pcall(function()
        if Character then
            for part, wasCollide in pairs(State.noclipSaved) do
                if part and part.Parent then
                    part.CanCollide = wasCollide
                end
            end
        end
    end)
    table.clear(State.noclipSaved)
end

-- Stop ESP | إيقاف ESP وتدمير الرسومات
local function stopESP()
    State.espOn = false
    State.espBoxOn = false
    State.espNameOn = false
    State.espDistOn = false
    if State.espConn then
        pcall(function() State.espConn:Disconnect() end)
        State.espConn = nil
    end
    for _, pack in pairs(State.espDrawings) do
        pcall(function()
            if pack.box then pack.box:Remove() end
            if pack.name then pack.name:Remove() end
            if pack.dist then pack.dist:Remove() end
            if pack.highlight then pack.highlight:Destroy() end
        end)
    end
    table.clear(State.espDrawings)
end

-- Restore name tag | استعادة الاسم
local NameToggleBtn

local function setNameHidden(hide)
    State.hideNameOn = hide
    if NameToggleBtn then
        if hide then
            NameToggleBtn.Text = "🙈 HIDE NAME | إخفاء الاسم"
            NameToggleBtn.TextColor3 = THEME.OffRed
        else
            NameToggleBtn.Text = "👁️ SHOW NAME | إظهار الاسم"
            NameToggleBtn.TextColor3 = THEME.Cyan
        end
    end
    local head = Character and Character:FindFirstChild("Head")
    if not head then return end
    pcall(function()
        for _, c in ipairs(head:GetChildren()) do
            if c:IsA("BillboardGui") then c.Enabled = not hide end
        end
        local hum = getHum()
        if hum then
            hum.DisplayDistanceType = hide and Enum.HumanoidDisplayDistanceType.None or Enum.HumanoidDisplayDistanceType.Viewer
        end
    end)
end

-- Restore all animations | استعادة المشية الافتراضية
local function restoreAnims()
    pcall(function()
        local anim = Character and Character:FindFirstChild("Animate")
        if not anim then return end
        for name, id in pairs(State.originalAnims) do
            local v = anim:FindFirstChild(name)
            if v and v:FindFirstChildOfClass("Animation") then
                v:FindFirstChildOfClass("Animation").AnimationId = id
            end
        end
        local hum = getHum()
        if hum then hum.WalkSpeed = State.walkSpeed end
    end)
end

-- Master Reset | إعادة ضبط كل شيء
local function resetAll()
    stopFlight()
    stopWalkBoost()
    stopEmote()
    stopInfJump()
    stopNoclip()
    stopESP()
    restoreAnims()
    if State.hideNameOn then setNameHidden(false) end
    State.flightSpeed = 50
    State.scaleIndex = 1
end

