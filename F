                -- إلغاء طلبات جيم باس اللعبة برمجياً | Terminate Roblox Prompts
                local corePrompt = CoreGuiService:FindFirstChild("PurchasePrompt")
                if corePrompt and corePrompt.Visible then
                    MarketService:SignalPromptPurchaseFinished()
