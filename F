local ESPDistBtn   = makeActionBtn(pgESP, "📏", "DISTANCE ESP", "المسافة", 44)

ESPMasterBtn.MouseButton1Click:Connect(function()
    if State.espOn then
        stopESP()
        ESPMasterBtn.Text = "👁️  MASTER ESP  |  تشغيل النظام"
        ESPMasterBtn.TextColor3 = THEME.TextWhite
    else
        startESP()
        ESPMasterBtn.Text = "✅  ESP ACTIVE  |  مفعّل"
        ESPMasterBtn.TextColor3 = THEME.TextGlow
    end
end)

local function toggleESPSub(flag, btn, onT, offT)
    if not State.espOn then startESP(); ESPMasterBtn.Text = "✅  ESP ACTIVE  |  مفعّل"; ESPMasterBtn.TextColor3 = THEME.TextGlow end
    State[flag] = not State[flag]
    if State[flag] then
        btn.Text = onT; btn.TextColor3 = THEME.TextGlow
    else
        btn.Text = offT; btn.TextColor3 = THEME.TextWhite
        if not State.espBoxOn and not State.espNameOn and not State.espDistOn then
            stopESP()
            ESPMasterBtn.Text = "👁️  MASTER ESP  |  تشغيل النظام"
            ESPMasterBtn.TextColor3 = THEME.TextWhite
        end
    end
end

ESPBoxBtn.MouseButton1Click:Connect(function()
    toggleESPSub("espBoxOn", ESPBoxBtn,
        "✅  BOX ESP ON  |  مفعّل", "📦  BOX ESP  |  مربع")
end)
ESPNameBtn.MouseButton1Click:Connect(function()
    toggleESPSub("espNameOn", ESPNameBtn,
        "✅  NAME ESP ON  |  مفعّل", "🏷️  NAME ESP  |  الاسم")
end)
ESPDistBtn.MouseButton1Click:Connect(function()
    toggleESPSub("espDistOn", ESPDistBtn,
        "✅  DISTANCE ON  |  مفعّل", "📏  DISTANCE ESP  |  المسافة")
end)

