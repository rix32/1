track(LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid  = char:WaitForChild("Humanoid")
    State.defaultWalk = Humanoid.WalkSpeed

    stopFlight()
    stopNoclip()
    stopEmote()
    table.clear(State.noclipSaved)

    task.wait(0.8)
    backupAnims(char)

    if State.walkBoostOn then
        pcall(function() Humanoid.WalkSpeed = State.walkSpeed end)
    end
    if State.hideNameOn then setNameHidden(true) end
    if State.infJumpOn then startInfJump() end
    if State.noclipOn then startNoclip() end
    if State.flightOn then startFlight() end
    if State.espOn then
        stopESP()
        startESP()
    end
end))

